{
  "name": "aitutor-notes",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "npm --workspace apps/frontend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:backend": "npm --workspace apps/backend run dev",
    "build": "npm --workspace apps/frontend run build && npm --workspace apps/backend run build",
    "build:frontend": "npm --workspace apps/frontend run build",
    "build:backend": "npm --workspace apps/backend run build",
    "test": "npm --workspace apps/backend run test",
    "preview": "npm --workspace apps/frontend run preview"
  }
}
