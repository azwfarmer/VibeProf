TUTOR_PRIMARY_PROVIDER=anthropic
TUTOR_PRIMARY_MODEL=claude-opus-4-8
TUTOR_PREMIUM_PROVIDER=anthropic
TUTOR_PREMIUM_MODEL=claude-fable-5
TUTOR_FALLBACK_PROVIDER=openai
TUTOR_FALLBACK_MODEL=gpt-5.5

VOICE_PRIMARY_PROVIDER=openai
VOICE_PRIMARY_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=cedar
VOICE_FALLBACK_PROVIDER=gemini
VOICE_FALLBACK_MODEL=gemini-3.1-flash-live-preview

anthropic_key=
openAI_key=
gemini_key=

# Also supported:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8787
AITUTOR_DB_PATH=apps/backend/data/aitutor.json

# Optional. Required by some iPad browsers for microphone/WebRTC on a LAN IP.
# HTTPS_CERT_PATH=apps/backend/data/local-cert.pem
# HTTPS_KEY_PATH=apps/backend/data/local-key.pem
# HTTPS_CA_CERT_PATH=apps/backend/data/local-ca.cer
# HTTP_HELPER_PORT=8788
